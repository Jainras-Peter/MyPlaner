rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }

    // Skills
    match /skills/{skillId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // Topics
    match /topics/{topicId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // SubTopics
    match /subtopics/{subTopicId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // Notes
    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // Habits
    match /habits/{habitId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }

    // Reflections
    match /reflections/{reflectionId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update, delete: if isDocOwner();
    }
  }
}
